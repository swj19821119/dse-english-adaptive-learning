    "adaptToLevel": {
      "1": "主要用简单的Main Idea和Specific Details题",
      "2": "混合Comprehension和Inference题",
      "3": "加入Critical Analysis和Multiple Perspectives题",
      "4": "主要用Implicit Meaning和Advanced Analysis题"
    }
