{
  "knowledgePoints": {
    "conditional_sentences": {
      "name": "Conditional Sentences (If...)",
      "difficulty": "foundation",
      "type": "grammar",
      "subtopics": [
        {
          "name": "Type 1: Real Future (If + Present, will + base verb)",
          "examples": ["If it rains, I will stay home"],
          "difficulty": 1,
          "questions": [
            {
              "id": "cond_1_1",
              "text": "If you study hard, you _____ pass the exam.",
              "options": ["A) will pass", "B) would pass", "C) would have passed", "D) pass"],
              "correct": "A",
              "explanation": "Type 1 conditional: certain future. Use 'will + base verb'."
            },
            {
              "id": "cond_1_2",
              "text": "If she calls, I _____ answer immediately.",
              "options": ["A) answer", "B) will answer", "C) would answer", "D) answered"],
              "correct": "B",
              "explanation": "Type 1: future certainty. Present + will + base verb."
            }
          ]
        },
        {
          "name": "Type 2: Imaginary Present (If + Past, would + base verb)",
          "examples": ["If I were rich, I would travel"],
          "difficulty": 2,
          "questions": [
            {
              "id": "cond_2_1",
              "text": "If I were you, I _____ this job.",
              "options": ["A) would accept", "B) accept", "C) would have accepted", "D) will accept"],
              "correct": "A",
              "explanation": "Type 2 conditional: imaginary present. If + past simple, would + base verb."
            },
            {
              "id": "cond_2_2",
              "text": "If he had more time, he _____ join us.",
              "options": ["A) will join", "B) would join", "C) joins", "D) joined"],
              "correct": "B",
              "explanation": "Type 2: impossible present situation. Use 'would + base verb'."
            }
          ]
        },
        {
          "name": "Type 3: Imaginary Past (If + Had + Past Participle, would have + Past Participle)",
          "examples": ["If I had known, I would have helped"],
          "difficulty": 3,
          "questions": [
            {
              "id": "cond_3_1",
              "text": "If I had known about the accident, I _____ my friend.",
              "options": ["A) would notify", "B) would have notified", "C) will notify", "D) have notified"],
              "correct": "B",
              "explanation": "Type 3 conditional: past regret. If + past perfect, would have + past participle."
            },
            {
              "id": "cond_3_2",
              "text": "If they had arrived earlier, they _____ the beginning.",
              "options": ["A) would see", "B) would have seen", "C) see", "D) had seen"],
              "correct": "B",
              "explanation": "Type 3: unfulfilled past condition. Use 'would have + past participle'."
            }
          ]
        }
      ]
    },
    "prepositions_gerund": {
      "name": "Prepositions + Gerund",
      "difficulty": "foundation",
      "type": "grammar",
      "subtopics": [
        {
          "name": "Basic Prepositions + -ing",
          "examples": ["despite studying, in addition to working"],
          "difficulty": 1,
          "questions": [
            {
              "id": "prep_1_1",
              "text": "Despite _____ hard, she failed the test.",
              "options": ["A) studying", "B) study", "C) to study", "D) studied"],
              "correct": "A",
              "explanation": "After prepositions, always use gerund (-ing form)."
            },
            {
              "id": "prep_1_2",
              "text": "In addition to _____ English, he studies French.",
              "options": ["A) study", "B) to study", "C) studying", "D) studies"],
              "correct": "C",
              "explanation": "Preposition 'in addition to' + gerund."
            }
          ]
        },
        {
          "name": "Advanced Preposition Phrases",
          "examples": ["instead of, by means of, without"],
          "difficulty": 2,
          "questions": [
            {
              "id": "prep_2_1",
              "text": "Instead of _____ home, he went to the gym.",
              "options": ["A) go", "B) going", "C) goes", "D) to go"],
              "correct": "B",
              "explanation": "'Instead of' is a preposition phrase requiring gerund."
            }
          ]
        }
      ]
    },
    "subjunctive_mood": {
      "name": "Subjunctive Mood",
      "difficulty": "intermediate",
      "type": "grammar",
      "subtopics": [
        {
          "name": "Subjunctive after demand/insist/suggest",
          "examples": ["I insist that she be present"],
          "difficulty": 2,
          "questions": [
            {
              "id": "subj_1_1",
              "text": "The manager insisted that the report _____ by Friday.",
              "options": ["A) is completed", "B) be completed", "C) will be completed", "D) has been"],
              "correct": "B",
              "explanation": "After 'insist', use subjunctive: that + be + past participle (passive)."
            }
          ]
        }
      ]
    },
    "reading_comprehension": {
      "name": "Reading Comprehension",
      "difficulty": "mixed",
      "type": "reading",
      "subtopics": [
        {
          "name": "Main Idea & Supporting Details",
          "difficulty": 1,
          "passages": [
            {
              "id": "read_1_1",
              "passage": "Renewable energy has emerged as one of the most critical solutions to combat climate change. Unlike fossil fuels, which release carbon dioxide and contribute to global warming, renewable energy sources such as solar and wind power generate electricity without producing harmful emissions.",
              "questions": [
                {
                  "id": "read_q_1_1",
                  "text": "What is the main advantage of renewable energy?",
                  "options": ["A) It is cheaper", "B) It produces no emissions", "C) It is available everywhere", "D) It is new"],
                  "correct": "B"
                }
              ]
            }
          ]
        },
        {
          "name": "Inference & Analysis",
          "difficulty": 2,
          "passages": [
            {
              "id": "read_2_1",
              "passage": "The study examined 500 participants over 10 years. Those who exercised regularly showed 40% lower rates of depression and anxiety compared to the sedentary group. Researchers concluded that physical activity significantly impacts mental health.",
              "questions": [
                {
                  "id": "read_q_2_1",
                  "text": "What can be inferred from the study?",
                  "options": ["A) Exercise causes depression", "B) All people should exercise", "C) Physical activity may improve mental health", "D) Depression prevents exercise"],
                  "correct": "C"
                }
              ]
            }
          ]
        }
      ]
    },
    "vocabulary": {
      "name": "Academic Vocabulary",
      "difficulty": "mixed",
      "type": "vocab",
      "words": [
        {
          "word": "resilient",
          "meaning": "able to recover quickly",
          "example": "The company was resilient enough to survive the crisis.",
          "difficulty": 2,
          "questions": [
            {
              "id": "vocab_1",
              "text": "Despite the challenges, the team remained _____.",
              "options": ["A) fragile", "B) resilient", "C) weak", "D) broken"],
              "correct": "B"
            }
          ]
        },
        {
          "word": "pragmatic",
          "meaning": "dealing with things in a practical way",
          "example": "His pragmatic approach solved the problem quickly.",
          "difficulty": 2,
          "questions": [
            {
              "id": "vocab_2",
              "text": "Instead of dreaming, she took a _____ approach to her career.",
              "options": ["A) romantic", "B) pragmatic", "C) lazy", "D) artistic"],
              "correct": "B"
            }
          ]
        }
      ]
    }
  },
